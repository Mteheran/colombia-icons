{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "declaration": true,
    "strict": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./out-tsc"
  },
  "angularCompilerOptions": { "compilationMode": "partial", "strictTemplates": true },
  "exclude": ["**/*.spec.ts"]
}
